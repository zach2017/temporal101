# ╔══════════════════════════════════════════════════════════════╗
# ║  Document Processing Pipeline – Docker Compose Environment  ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Temporal Server ───────────────────────────────────────────
TEMPORAL_HOST=host.docker.internal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=document-intake-queue
TEMPORAL_PDF_TASK_QUEUE=pdf-extraction-queue
TEMPORAL_OCR_TASK_QUEUE=image-ocr-queue
TEMPORAL_CONVERSION_TASK_QUEUE=document-conversion-queue
TEMPORAL_VERSION=latest
TEMPORAL_UI_VERSION=latest

# ── PostgreSQL (Temporal persistence) ─────────────────────────
POSTGRES_VERSION=17
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal
POSTGRES_PORT=5432

# ── LocalStack S3 ────────────────────────────────────────────
# Workers connect to LocalStack via host.docker.internal
S3_ENDPOINT_URL=http://host.docker.internal:4566
S3_BUCKET_NAME=document-processing
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_REGION=us-east-1
LOCALSTACK_VERSION=latest
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0
LOCALSTACK_PERSISTENCE=1

# ── Elasticsearch (no :latest tag — must pin a version) ───────
ELASTICSEARCH_VERSION=8.17.4
ELASTICSEARCH_PORT=9200

# ── Worker Tuning ─────────────────────────────────────────────
MAX_CONCURRENT_ACTIVITIES=5
ACTIVITY_HEARTBEAT_TIMEOUT_SECONDS=120
ACTIVITY_START_TO_CLOSE_TIMEOUT_SECONDS=600

# ── Document Source Mount ─────────────────────────────────────
DOCS_SOURCE_DIR=./sample_docs
