# ── Temporal Configuration ──
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pdf-extraction-queue
TEMPORAL_OCR_TASK_QUEUE=image-ocr-queue

# ── S3 Configuration (LocalStack) ──
# For local dev: LocalStack at localhost:4566
# For Docker Compose: http://localstack:4566
S3_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=document-processing
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_REGION=us-east-1

# ── PDF Source Configuration ──
PDF_SOURCE_DIR=/tmp/pdf_inbox

# ── Worker Configuration ──
MAX_CONCURRENT_ACTIVITIES=5
ACTIVITY_HEARTBEAT_TIMEOUT_SECONDS=120
ACTIVITY_START_TO_CLOSE_TIMEOUT_SECONDS=600
